<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Evidence_Filmů.ViewModels"
        xmlns:models="using:Evidence_Filmů.Models"
        x:Class="Evidence_Filmů.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="Evidence Filmů"
        Width="960" Height="660"
        MinWidth="720" MinHeight="500">

    <!-- Hlavní mřížka: záhlaví / filtry / seznam / stavový řádek -->
    <Grid RowDefinitions="Auto,Auto,*,Auto">

        <!-- ═══════════════════════════════════════════════════════════
             ZÁHLAVÍ — název aplikace + akční tlačítka
             ═══════════════════════════════════════════════════════════ -->
        <Border Grid.Row="0" Background="#2B2D31" Padding="18,12">
            <Grid ColumnDefinitions="*,Auto">

                <!-- Název aplikace vlevo -->
                <TextBlock Grid.Column="0"
                           Text="🎬  Evidence Filmů"
                           FontSize="20" FontWeight="Bold"
                           Foreground="White"
                           VerticalAlignment="Center"/>

                <!-- Tlačítka vpravo -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">

                    <!-- Přidat nový záznam -->
                    <Button x:Name="PridatBtn"
                            Content="＋  Přidat"
                            Click="OnPridatClick"
                            Background="#5865F2" Foreground="White"
                            FontWeight="SemiBold" Padding="14,7"/>

                    <!-- Správa žánrů -->
                    <Button x:Name="ZanryBtn"
                            Content="Žánry"
                            Click="OnZanryClick"
                            Padding="12,7"/>

                    <!-- Export do TXT souboru -->
                    <Button x:Name="ExportBtn"
                            Content="Export TXT"
                            Click="OnExportClick"
                            Padding="12,7"/>

                    <!-- Import z TXT souboru -->
                    <Button x:Name="ImportBtn"
                            Content="Import TXT"
                            Click="OnImportClick"
                            Padding="12,7"/>

                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════
             PANEL FILTRŮ — vyhledávání, filtr žánru a typu
             ═══════════════════════════════════════════════════════════ -->
        <Border Grid.Row="1" Background="#313338" Padding="18,8">
            <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">

                <!-- Vyhledávací pole -->
                <TextBlock Text="Hledat:"
                           Foreground="#B5BAC1"
                           VerticalAlignment="Center"/>
                <TextBox Text="{Binding SearchText}"
                         PlaceholderText="Název, žánr nebo popis…"
                         Width="240" VerticalAlignment="Center"/>

                <!-- Filtr podle žánru -->
                <TextBlock Text="Žánr:"
                           Foreground="#B5BAC1"
                           VerticalAlignment="Center"
                           Margin="10,0,0,0"/>
                <ComboBox ItemsSource="{Binding AvailableGenres}"
                          SelectedItem="{Binding SelectedGenreFilter}"
                          Width="165" VerticalAlignment="Center"/>

                <!-- Filtr podle typu (Film / Kniha / Vše) -->
                <TextBlock Text="Typ:"
                           Foreground="#B5BAC1"
                           VerticalAlignment="Center"
                           Margin="10,0,0,0"/>
                <ComboBox ItemsSource="{Binding TypeFilters}"
                          SelectedItem="{Binding SelectedTypeFilter}"
                          Width="100" VerticalAlignment="Center"/>

            </StackPanel>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════
             SEZNAM ZÁZNAMŮ — výsledky po aplikaci filtrů
             ═══════════════════════════════════════════════════════════ -->
        <ListBox Grid.Row="2"
                 x:Name="ZaznamyList"
                 ItemsSource="{Binding FilteredItems}"
                 SelectedItem="{Binding SelectedItem}"
                 Background="#1E1F22"
                 DoubleTapped="OnSeznamDoubleTapped"
                 Padding="6,4">

            <ListBox.ItemTemplate>
                <!-- Šablona jednoho řádku v seznamu -->
                <DataTemplate x:DataType="models:Item">

                    <Border Padding="12,9" CornerRadius="6"
                            Margin="2,2" Background="#2B2D31">

                        <Grid ColumnDefinitions="Auto,*,120,130">

                            <!-- Barevný štítek: 🎬 Film nebo 📚 Kniha -->
                            <Border Grid.Column="0"
                                    Background="#5865F2" CornerRadius="4"
                                    Padding="7,2" Margin="0,0,14,0"
                                    VerticalAlignment="Center">
                                <TextBlock Text="{Binding TypeLabel}"
                                           FontSize="11"
                                           Foreground="White"
                                           FontWeight="Bold"/>
                            </Border>

                            <!-- Název a žánr -->
                            <StackPanel Grid.Column="1"
                                        VerticalAlignment="Center"
                                        Spacing="2">
                                <TextBlock Text="{Binding Title}"
                                           FontSize="14"
                                           FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding Genre}"
                                           FontSize="11"
                                           Foreground="#B5BAC1"/>
                            </StackPanel>

                            <!-- Hodnocení (⭐ X.X) -->
                            <TextBlock Grid.Column="2"
                                       Text="{Binding RatingLabel}"
                                       Foreground="#FAA61A"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center"/>

                            <!-- Stav dokončení (✅ nebo ⏳) -->
                            <TextBlock Grid.Column="3"
                                       Text="{Binding StatusDisplay}"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Left"/>

                        </Grid>
                    </Border>

                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- ═══════════════════════════════════════════════════════════
             STAVOVÝ ŘÁDEK — statistiky + tlačítka pro vybranou položku
             ═══════════════════════════════════════════════════════════ -->
        <Border Grid.Row="3" Background="#2B2D31" Padding="18,8">
            <Grid ColumnDefinitions="*,Auto">

                <!-- Statistiky vlevo (celkem / filmů / knih) -->
                <TextBlock Grid.Column="0"
                           Text="{Binding StatusText}"
                           Foreground="#B5BAC1"
                           FontSize="12"
                           VerticalAlignment="Center"/>

                <!-- Tlačítka pro vybraný záznam vpravo -->
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            Spacing="8">

                    <!-- Zobrazit detail vybrané položky -->
                    <Button x:Name="DetailBtn"
                            Content="Podrobnosti"
                            Click="OnDetailClick"
                            Padding="10,5"/>

                    <!-- Upravit vybranou položku -->
                    <Button x:Name="UpravitBtn"
                            Content="✏  Upravit"
                            Click="OnUpravitClick"
                            Background="#4E5058" Foreground="White"
                            Padding="10,5"/>

                    <!-- Smazat vybranou položku -->
                    <Button x:Name="SmazatBtn"
                            Content="🗑  Smazat"
                            Click="OnSmazatClick"
                            Background="#ED4245" Foreground="White"
                            Padding="10,5"/>

                </StackPanel>
            </Grid>
        </Border>

    </Grid>
</Window>
