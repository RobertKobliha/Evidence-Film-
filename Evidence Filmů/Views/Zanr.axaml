<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Evidence_Filmů.Views.Zanr"
        Title="Správa žánrů" Width="340" Height="400"
        CanResize="False" WindowStartupLocation="CenterOwner">

    <Grid RowDefinitions="*,Auto" Margin="20">
        <StackPanel Grid.Row="0" Spacing="10">
            <TextBlock Text="Uložené žánry" FontSize="16" FontWeight="Bold"/>

            <ListBox x:Name="ZanrList" Height="220" Background="#2B2D31"/>

            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBox x:Name="NovyZanrBox" Watermark="Nový žánr…" Width="200"/>
                <Button Content="Přidat" Click="OnPridatClick" Background="#5865F2"
                        Foreground="White" Padding="10,6"/>
            </StackPanel>

            <TextBlock x:Name="ChybaLabel" Foreground="#ED4245" FontSize="12"/>
        </StackPanel>

        <Button Grid.Row="1" Content="Zavřít" HorizontalAlignment="Right"
                Click="OnZavritClick" Padding="14,7" Margin="0,12,0,0"/>
    </Grid>
</Window>